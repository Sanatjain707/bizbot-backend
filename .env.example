PORT=3000
NODE_ENV=development

# Groq — https://console.groq.com/keys
GROQ_API_KEY=gsk_REPLACE_ME
# Optional. Defaults to llama-3.3-70b-versatile. Groq's Llama models get
# rotated on their retirement schedule (https://console.groq.com/docs/models)
# — re-check before shipping to prod and pin an explicit version here.
# Fastest alternative: llama-3.1-8b-instant
GROQ_MODEL=llama-3.3-70b-versatile

# Supabase — https://supabase.com → project → Settings → API
SUPABASE_URL=https://REPLACE_ME.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.REPLACE_ME

# Meta WhatsApp — https://developers.facebook.com → app → WhatsApp → Getting Started
WHATSAPP_TOKEN=EAAXXXXXXX_REPLACE_ME
WHATSAPP_PHONE_ID=REPLACE_WITH_PHONE_NUMBER_ID
# The verify token is a string YOU pick and paste into Meta's webhook UI —
# it doesn't need to be secret, but pick a fresh random string per environment.
WHATSAPP_VERIFY_TOKEN=REPLACE_WITH_YOUR_OWN_STRING
# App Secret from Meta → App Settings → Basic. Signs incoming webhooks
# (x-hub-signature-256). MUST be set in production — without it, anyone
# can POST fake WhatsApps and make the bot send messages to arbitrary numbers.
WHATSAPP_APP_SECRET=REPLACE_ME

# Razorpay — https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_REPLACE_ME
RAZORPAY_KEY_SECRET=REPLACE_ME
# Set this in Razorpay dashboard → Webhooks. Signs the /api/billing/webhook
# payloads so we don't activate plans on spoofed events.
RAZORPAY_WEBHOOK_SECRET=REPLACE_ME

APP_URL=http://localhost:3000

# Frontend origin(s) allowed by CORS. Comma-separated for multiple.
# In production set this to your real dashboard URL — leaving it as * lets
# any website call your API on behalf of a logged-in browser.
FRONTEND_URL=http://localhost:3001

# Auth toggle for dashboard/business/broadcast/analytics routes. Set to
# "false" only during local migration — production MUST leave it on so the
# x-business-id header can't be spoofed.
AUTH_REQUIRED=true

# Operator console (/api/admin). Comma-separated allowlist of platform-admin
# emails — only these Supabase accounts can reach the admin dashboard.
ADMIN_EMAILS=you@yourdomain.com

# Error monitoring (optional). Paste your Sentry project DSN to capture backend
# errors + unhandled rejections. Leave blank to disable — everything works without it.
SENTRY_DSN=

# Logging: LOG_LEVEL=debug|info|warn|error; LOG_FORMAT=pretty|json.
# json is best for aggregators (Railway, Datadog). Defaults: info + pretty.
LOG_LEVEL=info
LOG_FORMAT=pretty
